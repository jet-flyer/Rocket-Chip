#!/bin/bash
# RocketChip pre-commit hook (tracked — set: git config core.hooksPath scripts/hooks)
#
# 1) <stdio.h> no-new-include gate (per docs/decisions/STDIO_REPLACEMENT_PLAN.md)
# 2) clang-tidy size/complexity on staged flight-classified C++ (see below)
# 3) Host ctest when build_host/ exists
# 4) Tier 6b: HW gates driven by scripts/ci/pre_commit_matrix.py (patterns in code + matrix doc)
#
# Emergency bypass: git commit --no-verify **only after receiving explicit permission from the repo owner in this session**

CLANG_TIDY="C:/Program Files/LLVM/bin/clang-tidy.exe"
REPO_ROOT="$(git rev-parse --show-toplevel)"
BUILD_DIR="${REPO_ROOT}/build"

# ============================================================================
# Gate 1: <stdio.h> banned in src/*.cpp
# ============================================================================
# Allowlist mechanism retired 2026-05-17 per R-5 Unit J closure. No
# src/*.cpp may include <stdio.h>. Use rc::rc_log / rc::rc_snprintf /
# rc::strbuf instead (include/rocketchip/rc_log.h).

STAGED_CPP=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^src/.*\.cpp$')

if [[ -n "${STAGED_CPP}" ]]; then
    STDIO_VIOLATIONS=""
    for src in ${STAGED_CPP}; do
        if git diff --cached -- "${src}" 2>/dev/null \
                | grep -q '^\+.*#include.*<stdio\.h>'; then
            STDIO_VIOLATIONS="${STDIO_VIOLATIONS}${src}\n"
        elif git show ":${src}" 2>/dev/null | grep -q '^[[:space:]]*#include[[:space:]]*<stdio\.h>'; then
            STDIO_VIOLATIONS="${STDIO_VIOLATIONS}${src}\n"
        fi
    done

    if [[ -n "${STDIO_VIOLATIONS}" ]]; then
        echo ""
        echo "=== Pre-commit: <stdio.h> banned in src/*.cpp ==="
        echo ""
        printf "  %b" "${STDIO_VIOLATIONS}"
        echo ""
        echo "Use rc::rc_log / rc::rc_snprintf / rc::strbuf (rocketchip/rc_log.h)."
        echo "Bypass only after receiving explicit permission from the repo owner in this session: git commit --no-verify"
        exit 1
    fi
fi

# ============================================================================
# Gate 2: clang-tidy gated checks + warning-flag coverage
# ============================================================================
# Single source of truth: scripts/audit/full_tree_clang_tidy.sh (function size,
# cognitive complexity, unchecked return [flash_safe_execute], reserved-id, and
# the compiler-flag-coverage check). The SAME script runs full-tree at milestone
# close (SESSION_CHECKLIST item 17) — the check list lives in ONE place, no
# longer hard-coded here AND there (LL 40 dual-hardcode defect, fixed 2026-06-24).
#
# Needs clang-tidy + build/compile_commands.json from a target configure
# (cmake -B build -G Ninja). If either is absent, Gate 2 is SKIPPED but Gates
# 3 + 4 below MUST still run (2026-05-20 fail-open lesson — LL Entry 36 / 40).

if [[ -x "${CLANG_TIDY}" ]] && [[ -f "${BUILD_DIR}/compile_commands.json" ]]; then
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^src/.*\.cpp$')
    if [[ -n "${STAGED_FILES}" ]]; then
        if ! bash "${REPO_ROOT}/scripts/audit/full_tree_clang_tidy.sh" ${STAGED_FILES}; then
            echo ""
            echo "Commit blocked: fix the flagged functions / returns / coverage before committing."
            echo "Bypass only after receiving explicit permission from the repo owner in this session: git commit --no-verify"
            exit 1
        fi
    fi
fi

HOST_BUILD="${REPO_ROOT}/build_host"
if [[ -d "${HOST_BUILD}" ]] && [[ -f "${HOST_BUILD}/CTestTestfile.cmake" ]]; then
    echo "pre-commit: running host tests..."
    (cd "${HOST_BUILD}" && ctest --output-on-failure)
    CTEST_RC=$?
    if [[ ${CTEST_RC} -ne 0 ]]; then
        echo ""
        echo "PRE-COMMIT BLOCKED: host tests failed"
        exit 1
    fi
    echo "pre-commit: host tests OK"
fi

# Tier 6b — MATRIX-driven triggers (scripts/ci/pre_commit_matrix.py)
#
# Policy 2026-05-16 (council unanimous, citing R-25-exec precedent +
# LL Entries 36 + 39): "categories not enumerations." The matrix
# triggers TRIGGER_FLIGHT_BENCH=1 on ANY change that can produce a
# different rocketchip.elf — not just specific flight-director paths.
# Pure-doc / pure-test / pure-tooling changes are exempt by virtue of
# not matching the regex, NOT by explicit carve-out. Rationale in
# scripts/ci/pre_commit_matrix.py header comment.
TRIGGER_FLIGHT_BENCH=0
TRIGGER_STATION_BENCH=0
eval "$(python "${REPO_ROOT}/scripts/ci/pre_commit_matrix.py")"

if [[ "${TRIGGER_FLIGHT_BENCH}" == "1" ]]; then
    echo "pre-commit: firmware-affecting path touched — HW verification needed"

    HW_READY=0
    if netstat -an 2>/dev/null | grep -q "127.0.0.1:3333.*LISTENING"; then
        HW_READY=1
    fi

    if [[ ${HW_READY} -eq 1 ]]; then
        echo "pre-commit: running bench sim (auto-detecting target port)..."
        if ! python -u "${REPO_ROOT}/scripts/bench_sim.py"; then
            echo ""
            echo "PRE-COMMIT BLOCKED: bench sim HW test failed"
            exit 1
        fi
        echo "pre-commit: bench sim OK"
    else
        echo ""
        echo "HW VERIFICATION NEEDED BUT OPENOCD NOT ON localhost:3333"
        echo "(bench_sim gate — see docs/CONFIG_TEST_MATRIX.md, LL Entry 36 + 39)"
        echo "Start OpenOCD per docs/agents/DEBUG_PROBE_NOTES.md, or use"
        echo "--no-verify only after receiving explicit permission from the repo owner in this session."
        exit 1
    fi
fi

if [[ "${TRIGGER_STATION_BENCH}" == "1" ]]; then
    echo "pre-commit: station-relevant path touched — station HW verification needed"

    STATION_PRESENT=0
    if python -c "
import serial.tools.list_ports, sys
for p in serial.tools.list_ports.comports():
    if p.vid == 0x2E8A and p.pid == 0x0009:
        sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
        STATION_PRESENT=1
    fi

    if [[ ${STATION_PRESENT} -eq 1 ]]; then
        echo "pre-commit: running station bench sim..."
        python -u "${REPO_ROOT}/scripts/station_bench_sim.py"
        STATION_RC=$?
        if [[ ${STATION_RC} -eq 0 ]]; then
            echo "pre-commit: station bench sim OK"
        elif [[ ${STATION_RC} -eq 2 ]]; then
            echo "pre-commit: station bench sim SKIPPED (no station firmware on bus)"
        else
            echo ""
            echo "PRE-COMMIT BLOCKED: station bench sim failed (rc=${STATION_RC})"
            exit 1
        fi
    else
        echo ""
        echo "STATION HW VERIFICATION NEEDED BUT BOARD NOT PRESENT"
        exit 1
    fi
fi

exit 0

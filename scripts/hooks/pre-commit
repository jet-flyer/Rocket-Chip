#!/bin/bash
# RocketChip pre-commit hook (tracked — set: git config core.hooksPath scripts/hooks)
#
# 1) <stdio.h> no-new-include gate (per docs/decisions/STDIO_REPLACEMENT_PLAN.md)
# 2) clang-tidy size/complexity on staged flight-classified C++ (see below)
# 3) Host ctest when build_host/ exists
# 4) Tier 6b: HW gates driven by scripts/ci/pre_commit_matrix.py (patterns in code + matrix doc)
#
# Emergency bypass: git commit --no-verify (repo-owner approval only)

CLANG_TIDY="C:/Program Files/LLVM/bin/clang-tidy.exe"
REPO_ROOT="$(git rev-parse --show-toplevel)"
BUILD_DIR="${REPO_ROOT}/build"
TOOLCHAIN="C:/Users/pow-w/.pico-sdk/toolchain/14_2_Rel1"

# ============================================================================
# Gate 1: <stdio.h> no-new-include
# ============================================================================
# Per docs/decisions/STDIO_REPLACEMENT_PLAN.md, no new src/ .cpp file may
# include <stdio.h>. Existing files that currently include it are listed in
# scripts/hooks/stdio_allowlist.txt; as the R-5 dedicated sessions migrate
# them, they come off the list. When the list is empty, the gate becomes
# "no <stdio.h> anywhere in src/*.cpp."
#
# Independent of any tool availability — this gate runs even when the
# toolchain checks below are skipped.

STDIO_ALLOWLIST="${REPO_ROOT}/scripts/hooks/stdio_allowlist.txt"
STAGED_CPP=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^src/.*\.cpp$')

if [[ -n "${STAGED_CPP}" && -f "${STDIO_ALLOWLIST}" ]]; then
    STDIO_VIOLATIONS=""
    for src in ${STAGED_CPP}; do
        # Does the staged content include <stdio.h>?
        if git diff --cached -- "${src}" 2>/dev/null \
                | grep -q '^\+.*#include.*<stdio\.h>'; then
            HAS_STDIO=1
        elif git show ":${src}" 2>/dev/null | grep -q '^[[:space:]]*#include[[:space:]]*<stdio\.h>'; then
            HAS_STDIO=1
        else
            HAS_STDIO=0
        fi

        if [[ ${HAS_STDIO} -eq 1 ]]; then
            # Is the file on the allowlist?
            if ! grep -qxF "${src}" "${STDIO_ALLOWLIST}"; then
                STDIO_VIOLATIONS="${STDIO_VIOLATIONS}${src}\n"
            fi
        fi
    done

    if [[ -n "${STDIO_VIOLATIONS}" ]]; then
        echo ""
        echo "=== Pre-commit: <stdio.h> no-new-include gate ==="
        echo ""
        echo "The following staged file(s) include <stdio.h> but are NOT on the"
        echo "allowlist (scripts/hooks/stdio_allowlist.txt):"
        echo ""
        printf "  %b" "${STDIO_VIOLATIONS}"
        echo ""
        echo "Per docs/decisions/STDIO_REPLACEMENT_PLAN.md, no new src/ .cpp may"
        echo "include <stdio.h>. Use rc::rc_log, ETL (etl::to_string /"
        echo "etl::format), or const char[] arrays instead. See"
        echo "docs/STDIO_TO_RC_LOG_MIGRATION_GUIDE.md for the cheat-sheet."
        echo ""
        echo "If this <stdio.h> use is genuinely unavoidable, the allowlist may"
        echo "be expanded with explicit user-cosigned commit-message"
        echo "justification + corresponding PROBLEM_REPORTS.md entry."
        echo ""
        echo "Bypass only with repo-owner approval: git commit --no-verify"
        exit 1
    fi
fi

# ============================================================================
# Gate 2: clang-tidy function size / complexity
# ============================================================================

if [[ ! -x "${CLANG_TIDY}" ]]; then
    exit 0
fi
if [[ ! -f "${BUILD_DIR}/compile_commands.json" ]]; then
    exit 0
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM \
    | grep '^src/.*\.cpp$' \
    | grep -v 'eskf_codegen\.cpp$' \
    | grep -v '^src/cli/' \
    | grep -v '^src/dev/')

if [[ -z "${STAGED_FILES}" ]]; then
    exit 0
fi

EXTRA_ARGS=(
    --extra-arg="--sysroot=${TOOLCHAIN}/arm-none-eabi"
    --extra-arg="--target=armv8m.main-none-eabi"
    --extra-arg="-isystem"
    --extra-arg="${TOOLCHAIN}/arm-none-eabi/include/c++/14.2.1"
    --extra-arg="-isystem"
    --extra-arg="${TOOLCHAIN}/arm-none-eabi/include/c++/14.2.1/arm-none-eabi/thumb/v8-m.main+fp/softfp"
    --extra-arg="-Wno-format-security"
    --extra-arg="-Wno-gnu-zero-variadic-macro-arguments"
)

FOUND=0

for src in ${STAGED_FILES}; do
    FILE_PATH="${REPO_ROOT}/${src}"

    OUTPUT=$("${CLANG_TIDY}" "${FILE_PATH}" -p "${BUILD_DIR}/" \
        --checks="-*,readability-function-size,readability-function-cognitive-complexity" \
        "${EXTRA_ARGS[@]}" 2>&1 \
        | grep -E "warning:.*readability-function-(size|cognitive-complexity)")

    if [[ -n "${OUTPUT}" ]]; then
        if [[ ${FOUND} -eq 0 ]]; then
            echo ""
            echo "=== Pre-commit: function size / complexity gate ==="
            echo ""
        fi
        echo "${OUTPUT}"
        FOUND=1
    fi
done

if [[ ${FOUND} -eq 1 ]]; then
    echo ""
    echo "Commit blocked: decompose the flagged functions before committing."
    echo "Bypass only with repo-owner approval: git commit --no-verify"
    exit 1
fi

HOST_BUILD="${REPO_ROOT}/build_host"
if [[ -d "${HOST_BUILD}" ]] && [[ -f "${HOST_BUILD}/CTestTestfile.cmake" ]]; then
    echo "pre-commit: running host tests..."
    (cd "${HOST_BUILD}" && ctest --output-on-failure)
    CTEST_RC=$?
    if [[ ${CTEST_RC} -ne 0 ]]; then
        echo ""
        echo "PRE-COMMIT BLOCKED: host tests failed"
        exit 1
    fi
    echo "pre-commit: host tests OK"
fi

# Tier 6b — MATRIX-driven triggers (scripts/ci/pre_commit_matrix.py)
#
# Policy 2026-05-16 (council unanimous, citing R-25-exec precedent +
# LL Entries 36 + 39): "categories not enumerations." The matrix
# triggers TRIGGER_FLIGHT_BENCH=1 on ANY change that can produce a
# different rocketchip.elf — not just specific flight-director paths.
# Pure-doc / pure-test / pure-tooling changes are exempt by virtue of
# not matching the regex, NOT by explicit carve-out. Rationale in
# scripts/ci/pre_commit_matrix.py header comment.
TRIGGER_FLIGHT_BENCH=0
TRIGGER_STATION_BENCH=0
eval "$(python "${REPO_ROOT}/scripts/ci/pre_commit_matrix.py")"

if [[ "${TRIGGER_FLIGHT_BENCH}" == "1" ]]; then
    echo "pre-commit: firmware-affecting path touched — HW verification needed"

    HW_READY=0
    if netstat -an 2>/dev/null | grep -q "127.0.0.1:3333.*LISTENING"; then
        HW_READY=1
    fi

    if [[ ${HW_READY} -eq 1 ]]; then
        echo "pre-commit: running bench sim (auto-detecting target port)..."
        if ! python -u "${REPO_ROOT}/scripts/bench_sim.py"; then
            echo ""
            echo "PRE-COMMIT BLOCKED: bench sim HW test failed"
            exit 1
        fi
        echo "pre-commit: bench sim OK"
    else
        echo ""
        echo "HW VERIFICATION NEEDED BUT OPENOCD NOT ON localhost:3333"
        echo "(bench_sim gate — see docs/CONFIG_TEST_MATRIX.md, LL Entry 36 + 39)"
        echo "Start OpenOCD per .claude/DEBUG_PROBE_NOTES.md, or use"
        echo "--no-verify with repo-owner approval for emergency bypass."
        exit 1
    fi
fi

if [[ "${TRIGGER_STATION_BENCH}" == "1" ]]; then
    echo "pre-commit: station-relevant path touched — station HW verification needed"

    STATION_PRESENT=0
    if python -c "
import serial.tools.list_ports, sys
for p in serial.tools.list_ports.comports():
    if p.vid == 0x2E8A and p.pid == 0x0009:
        sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
        STATION_PRESENT=1
    fi

    if [[ ${STATION_PRESENT} -eq 1 ]]; then
        echo "pre-commit: running station bench sim..."
        python -u "${REPO_ROOT}/scripts/station_bench_sim.py"
        STATION_RC=$?
        if [[ ${STATION_RC} -eq 0 ]]; then
            echo "pre-commit: station bench sim OK"
        elif [[ ${STATION_RC} -eq 2 ]]; then
            echo "pre-commit: station bench sim SKIPPED (no station firmware on bus)"
        else
            echo ""
            echo "PRE-COMMIT BLOCKED: station bench sim failed (rc=${STATION_RC})"
            exit 1
        fi
    else
        echo ""
        echo "STATION HW VERIFICATION NEEDED BUT BOARD NOT PRESENT"
        exit 1
    fi
fi

exit 0

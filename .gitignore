# Graphify: the auto-rebuilt ROOT outputs are gitignored (regenerated locally by
# the post-commit hook every commit -> otherwise they leave the working tree
# perpetually dirty; graphify issue #1018 fixed the rebuild LOOP but not the
# dirty-tree-from-tracking, and upstream assumes most users don't track these).
# The query tool reads the LOCAL file regardless of git, so nothing is lost.
# Protected snapshot subdirs (claude-build-*/, grok-build-*/) stay TRACKED as
# frozen baselines — these patterns match root files only, not the subdirs.
# Untracked + ignored 2026-06-29 (Claude); see AGENT_WHITEBOARD.md.
graphify-out/cost.json
graphify-out/cache/
graphify-out/graph.json
graphify-out/graph.html
graphify-out/GRAPH_REPORT.md
graphify-out/manifest.json
graphify-out/.graphify_analysis.json
graphify-out/.graphify_labels.json
graphify-out/.graphify_root
graphify-out/.curate_flag.json
graphify-out/.curate_state.json
# Auto-backup folders graphify writes on rebuild (bare YYYY-MM-DD/). The named
# protected snapshots (claude-build-*/, grok-build-*/) do NOT match this and stay tracked.
graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# MCP tool-definition cache (generated, not project source)
mcps/
